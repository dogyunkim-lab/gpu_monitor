# GPU Monitor 설정 예시
# 이 파일을 config.yaml로 복사하여 사용하세요.

vms:
  - host: "gpu-vm-01"
    port: 9400
    name: "GPU-VM-01"
  - host: "gpu-vm-02"
    port: 9400
    name: "GPU-VM-02"
  - host: "gpu-vm-03"
    port: 9400
    name: "GPU-VM-03"
  - host: "gpu-vm-04"
    port: 9400
    name: "GPU-VM-04"
  - host: "gpu-vm-05"
    port: 9400
    name: "GPU-VM-05"

collector:
  interval_seconds: 1.0      # 수집 간격 (초)
  timeout_seconds: 2.0        # HTTP 타임아웃 (초)
  max_consecutive_failures: 3  # 연속 실패 시 down 표시

storage:
  db_path: "gpu_metrics.db"
  retention_days: 7

recorder:
  interval_ms: 100            # 고해상도 기록 간격 (ms)
  output_dir: "recordings"

alerts:
  gpu_util_threshold: 95.0         # GPU 사용률 경고 임계값 (%)
  gpu_util_duration_seconds: 10    # 지속 시간 (초)
  temperature_threshold: 80.0      # 온도 경고 (°C)
  vram_util_threshold: 95.0        # VRAM 사용률 경고 (%)
  log_file: "alerts.log"

web:
  host: "0.0.0.0"
  port: 5555
  refresh_seconds: 5
