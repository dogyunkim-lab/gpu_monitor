{
  "uid": "vllm-monitor",
  "title": "vLLM 서비스 모니터링 & 진단",
  "tags": [
    "vllm",
    "llm",
    "inference",
    "diagnostic"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "모델",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": "label_values(vllm:num_requests_running, model_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "instance",
        "label": "서버",
        "type": "query",
        "datasource": {
          "type": "prometheus"
        },
        "query": "label_values(vllm:num_requests_running, instance)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "interval",
        "label": "집계 간격",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "text": "1m",
          "value": "1m"
        },
        "auto": true,
        "auto_count": 30,
        "auto_min": "10s"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "현재 상태",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "처리 중 요청",
      "description": "현재 GPU에서 추론이 진행 중인 요청 수.\n이 값이 높으면 서버가 활발히 일하고 있는 상태.",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(vllm:num_requests_running{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "대기 중 요청",
      "description": "GPU 자원(KV Cache) 부족으로 큐에서 대기 중인 요청 수.\n0이 정상. 지속적으로 높으면 서버 증설 필요.",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "첫 토큰 응답시간 (p90)",
      "description": "요청 후 첫 토큰 생성까지 걸리는 시간.\n사용자 체감 '대기 시간'에 해당.\np90 = 전체 요청의 90%가 이 시간 이내.",
      "type": "stat",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(vllm:time_to_first_token_seconds_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "KV Cache 사용률",
      "description": "GPU 메모리에서 KV Cache가 차지하는 비율.\n90% 이상이면 새 요청을 받을 수 없어 큐에 쌓이기 시작.\nPreemption 없이도 처리량이 크게 저하됨.",
      "type": "gauge",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "avg(vllm:gpu_cache_usage_perc{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "row",
      "title": "⚡ E2E 시간 분해 (핵심 진단)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "E2E 지연시간 분해 (p90)",
      "description": "쌓인 영역(큐 대기 + 프리필 + 디코드)과 빨간 점선(E2E 전체)의 차이가\n'phantom time' — 메트릭에 잡히지 않는 소요 시간.\n\n판정 기준:\n· gap < 1초: 정상. 시간 성분이 잘 맞음\n· gap 10~30초: 엔진 내부 대기 (chunked prefill 청크 사이 등)\n· gap > 30초: 엔진 외부 문제 의심 → 'Inference vs E2E' 패널 확인",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(vllm:request_queue_time_seconds_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "큐 대기 (p90)"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(vllm:request_prefill_time_seconds_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "프리필 연산 (p90)"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(vllm:request_decode_time_seconds_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "C",
          "legendFormat": "디코드 연산 (p90)"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(vllm:e2e_request_latency_seconds_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "D",
          "legendFormat": "E2E 전체 (p90)"
        }
      ],
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "E2E 전체 (p90)"
            },
            "properties": [
              {
                "id": "custom.stacking",
                "value": {
                  "mode": "none"
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    5
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "요청 특성 분석",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "프롬프트 토큰 수 분포",
      "description": "요청당 프롬프트(입력) 토큰 수의 분포.\n\n판정 기준:\n· p50 vs p99 격차 10배 이상 → 롱테일 존재\n  → p90 TTFT가 긴 프롬프트 요청들에 의해 끌어올려진 것\n· p99 > 50k → 롱테일이 TTFT 악화의 주범\n· p99 < 10k → 롱테일 아님, 다른 원인",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5,  sum(rate(vllm:request_prompt_tokens_bucket{model_name=~\"$model\", instance=~\"$instance\"}[5m])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "중앙값 (p50)"
        },
        {
          "expr": "histogram_quantile(0.9,  sum(rate(vllm:request_prompt_tokens_bucket{model_name=~\"$model\", instance=~\"$instance\"}[5m])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:request_prompt_tokens_bucket{model_name=~\"$model\", instance=~\"$instance\"}[5m])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "C",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(1.0,  sum(rate(vllm:request_prompt_tokens_bucket{model_name=~\"$model\", instance=~\"$instance\"}[5m])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "D",
          "legendFormat": "최대값 (max)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 10,
      "title": "이터레이션당 처리 토큰 수",
      "description": "스케줄러 1회 실행(iteration)에서 처리하는 토큰 수.\nChunked prefill의 청크 크기를 간접 반영.\n\n판정 기준:\n· p90 ≈ 2048 → 기본 청크 크기 사용 중\n· --max-num-batched-tokens를 16384로 올리면 이 값도 증가해야 함\n· 너무 작으면 스케줄링 오버헤드 누적",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5,  sum(rate(vllm:iteration_tokens_total_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "중앙값 (p50)"
        },
        {
          "expr": "histogram_quantile(0.9,  sum(rate(vllm:iteration_tokens_total_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:iteration_tokens_total_bucket{model_name=~\"$model\", instance=~\"$instance\"}[$interval])) by (le))",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "동시성 & 자원 상태",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "동시 요청 수 (실행/대기/스왑)",
      "description": "실행 중, 대기 중, 스왑된 요청 수의 시계열.\n\n판정 기준:\n· waiting 쌓이는데 Queue Wait이 10us → 메트릭 정의 불일치\n· swapped ≠ 0 → CPU 스왑 발생 (preemption 카운터에 안 잡힘)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(vllm:num_requests_running{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "실행 중"
        },
        {
          "expr": "sum(vllm:num_requests_waiting{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "대기 중"
        },
        {
          "expr": "sum(vllm:num_requests_swapped{model_name=~\"$model\", instance=~\"$instance\"})",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "C",
          "legendFormat": "스왑됨"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "title": "KV Cache 사용률 추이",
      "description": "GPU 및 CPU KV Cache 점유율 변화.\n\n판정 기준:\n· GPU > 90% 지속 + waiting 쌓임 → 메모리 병목\n  → FP8 전환 또는 max_model_len 축소 고려\n· waiting 0 + KV < 70% → 리소스 여유, 튜닝 이슈 아님",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc{model_name=~\"$model\", instance=~\"$instance\"}",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "GPU KV Cache"
        },
        {
          "expr": "vllm:cpu_cache_usage_perc{model_name=~\"$model\", instance=~\"$instance\"}",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "CPU KV Cache"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 14,
      "title": "Preemption 발생률",
      "description": "Preemption(요청 중단 후 재계산) 발생 빈도.\n\n판정 기준:\n· 0 유지 → preemption이 원인은 아님\n· 간헐적 스파이크 → KV 압박 시 발생\n· rate = 초당 횟수, increase = 5분 누적",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(vllm:num_preemptions_total{model_name=~\"$model\", instance=~\"$instance\"}[$interval])",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "A",
          "legendFormat": "Preemption/초"
        },
        {
          "expr": "increase(vllm:num_preemptions_total{model_name=~\"$model\", instance=~\"$instance\"}[5m])",
          "datasource": {
            "type": "prometheus"
          },
          "refId": "B",
          "legendFormat": "5분간 누적"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
